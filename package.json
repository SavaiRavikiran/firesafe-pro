{
  "name": "firesafe-pro",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @firesafe-pro/api prisma:generate",
    "db:migrate": "pnpm --filter @firesafe-pro/api prisma:migrate",
    "db:seed": "pnpm --filter @firesafe-pro/api prisma:seed"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  }
}
